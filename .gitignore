# Build artifact — regenerated by .claude/scripts/publish.sh and uploaded to Drive
wiki.zip

# Source documents — kept local, never committed. Folder skeleton ships via .gitkeep
# so consumers see where to drop content.
raw/*
!raw/.gitkeep
!raw/*/
raw/*/*
!raw/*/.gitkeep

# Maintainer scratchpad — never committed
deliverables/*
!deliverables/.gitkeep

# Local-only Claude settings (per-machine; not part of the template)
.claude/settings.local.json

# macOS
.DS_Store

# Office lock files
~$*

# Python (in case the build scripts get used)
__pycache__/
*.pyc
.venv/
venv/
